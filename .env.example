# Your Polymarket wallet
POLY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLY_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS_HERE

# Target wallet to copy (default: BAdiosB)
TARGET_WALLET=0x909fa9f89976058b8b3ab87adc502ec7415ea8c3

# Copy settings
COPY_RATIO=0.1          # 10% of target's bet size
MAX_BET_USD=10           # Hard cap per trade in USD
MIN_BET_USD=1            # Skip trades below this
POLL_INTERVAL=30         # Seconds between checks
MAX_PRICE=0.95           # Don't buy above this price
MIN_PRICE=0.05           # Don't buy below this price
COOLDOWN_SEC=10          # Min seconds between orders

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
